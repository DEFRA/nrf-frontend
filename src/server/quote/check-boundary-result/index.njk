{% extends "layouts/page.njk" %}

{% block pageTitle %}{% if validationErrors %}Error: {% endif %}{{ pageTitle }}{% endblock %}

{% block beforeContent %}
  {{ backLink({href: backLinkPath}) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">

        {% if validationErrors %}
        {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: validationErrors.summary
        }) }}
        {% endif %}

        <h1 class="govuk-heading-l">{{ pageHeading }}</h1>

        <p class="govuk-body">
            Your boundary file has been validated successfully.
            {{ featureCount }} feature{{ "s" if featureCount != 1 }} found.
        </p>

        {{ govukInsetText({
            text: "Check that the boundary shown below is correct before continuing."
        }) }}

        <div id="boundary-map" class="govuk-!-margin-bottom-6" data-geojson='{{ boundaryGeojson | safe }}'>
            <p class="govuk-body govuk-!-margin-bottom-0">Map view is not available. The boundary data has been validated.</p>
        </div>

        <h2 class="govuk-heading-m">EDP boundary check</h2>
        <p class="govuk-body">
            Intersects EDP: <strong>{{ "Yes" if intersectsEdp else "No" }}</strong>
        </p>
        {% if intersectsEdp %}
        <p class="govuk-body">
            Intersecting EDPs: {{ intersectingEdps | length }}
        </p>
        <ul class="govuk-list govuk-list--bullet">
            {% for edp in intersectingEdps %}
            <li>{{ edp.label }}{% if edp.n2k_site_name %} ({{ edp.n2k_site_name }}){% endif %}</li>
            {% endfor %}
        </ul>
        {% endif %}

        <details class="govuk-details govuk-!-margin-bottom-6">
            <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">Full API response</span>
            </summary>
            <div class="govuk-details__text">
                <pre style="max-height: 400px; overflow: auto; padding: 15px; background-color: #f3f2f1; border: 1px solid #b1b4b6; font-size: 11px; line-height: 1.5;">{{ boundaryResponseJson }}</pre>
            </div>
        </details>

        <form method="post" novalidate>
            {% include "partials/csrf-token.njk" %}

            {{ govukRadios({
                name: "boundaryCorrect",
                value: formSubmitData.boundaryCorrect,
                errorMessage: validationErrors.messagesByFormField.boundaryCorrect if validationErrors,
                fieldset: {
                    legend: {
                        text: "Is this boundary correct?",
                        classes: "govuk-fieldset__legend--m"
                    }
                },
                items: [
                    { value: "yes", text: "Yes, continue" },
                    { value: "no", text: "No, upload a different file" }
                ]
            }) }}

            {{ govukButton({
                text: "Continue",
                preventDoubleClick: true
            }) }}
        </form>

    </div>
</div>
{% endblock %}

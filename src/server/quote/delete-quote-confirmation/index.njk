{% extends "layouts/page.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block content %}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
        {{ govukPanel({
            titleText: pageHeading
        }) }}

        <h2 class="govuk-heading-m">What happens next</h2>
        <p class="govuk-body">Your quote details have been removed and deleted.</p>
        <p class="govuk-body">
            <a href="/" class="govuk-link">Get another quote</a>
        </p>

        <h2 class="govuk-heading-m">Get help with Nature Restoration Fund</h2>
        <p class="govuk-body">If you need help with Nature Restoration Fund, contact XXXX and give the NRF reference number.</p>
        <p class="govuk-body">
            Email: <a href="mailto:xxxxx@defra.gov.uk" class="govuk-link">xxxxx@defra.gov.uk</a><br>
            Telephone: 00000000000<br>
            Monday to Friday, 8:30am to 5pm, except bank holidays
        </p>
        <p class="govuk-body">
            <a href="#" class="govuk-link">Find out about call charges</a>
        </p>
    </div>
</div>
{% endblock %}

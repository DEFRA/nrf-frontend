{% extends "layouts/page.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block beforeContent %}
  {{ backLink({href: backLinkPath}) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds-from-desktop">

    <h1 class="govuk-heading-l">{{ pageHeading }}</h1>

    <p class="govuk-body">Please use the existing Habitat Regulations to meet your environmental obligations.</p>

    <p class="govuk-body">
      <a href="#" class="govuk-link" target="_blank" rel="noreferrer noopener">Find out about Habitat Regulations (opens in new tab)</a>
    </p>

  </div>
</div>
{% endblock %}

{% extends "layouts/page.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% set mainClasses = "app-main-wrapper app-main-wrapper--draw-boundary" %}

{% block head %}
  {{ super() }}
  <link href="{{ getAssetPath('interactive-map/index.css') }}" rel="stylesheet">
  <link href="{{ getAssetPath('interactive-map/plugins/map-styles/index.css') }}" rel="stylesheet">
  <script src="{{ getAssetPath('interactive-map/core/index.js') }}" defer nonce="{{ nonce }}"></script>
  <script src="{{ getAssetPath('interactive-map/maplibre/index.js') }}" defer nonce="{{ nonce }}"></script>
  <script src="{{ getAssetPath('interactive-map/plugins/map-styles/index.js') }}" defer nonce="{{ nonce }}"></script>
  <script src="{{ getAssetPath('draw-boundary-map.js') }}" defer nonce="{{ nonce }}"></script>
{% endblock %}

{% block beforeContent %}
  {{ backLink({href: backLinkPath}) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row app-draw-boundary">
  <div class="govuk-grid-column-full app-draw-boundary__column">
        <h1 class="govuk-heading-l">{{ pageHeading }}</h1>

        <div
          id="draw-boundary-map"
          class="app-draw-boundary__map"
          data-map-style-url="{{ mapStyleUrl }}"
        >
            <p class="govuk-body govuk-!-margin-bottom-0">Map view is not available.</p>
        </div>
    </div>
</div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
{% endblock %}

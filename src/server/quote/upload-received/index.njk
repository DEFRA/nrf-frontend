{% extends "layouts/page.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block head %}
  {{ super() }}
  {% if refreshInterval %}
  <meta http-equiv="refresh" content="{{ refreshInterval }}">
  {% endif %}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">

        <h1 class="govuk-heading-l">{{ pageHeading }}</h1>

        {% if errorMessage %}
        {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: [{
                text: errorMessage
            }]
        }) }}
        {% endif %}

        {% if isProcessing %}
        <p class="govuk-body">Your file is being processed. This page will automatically refresh.</p>
        <p class="govuk-body">
            <strong>Status:</strong> {{ status }}
        </p>
        {% else %}
        <p class="govuk-body">
            <strong>Status:</strong> {{ status }}
        </p>
        {% endif %}

    </div>
</div>
{% endblock %}

{% extends "layouts/page.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block head %}
  {{ super() }}
  <script src="{{ getAssetPath('interactive-map/core/index.js') }}" defer nonce="{{ nonce }}"></script>
  <script src="{{ getAssetPath('interactive-map/maplibre/index.js') }}" defer nonce="{{ nonce }}"></script>
  <script src="{{ getAssetPath('interactive-map/plugins/datasets/index.js') }}" defer nonce="{{ nonce }}"></script>
  <script src="{{ getAssetPath('interactive-map/plugins/map-styles/index.js') }}" defer nonce="{{ nonce }}"></script>
  <script src="{{ getAssetPath('upload-preview-map.js') }}" defer nonce="{{ nonce }}"></script>
  <link href="{{ getAssetPath('interactive-map/index.css') }}" rel="stylesheet">
  <link href="{{ getAssetPath('interactive-map/plugins/datasets/index.css') }}" rel="stylesheet">
  <link href="{{ getAssetPath('interactive-map/plugins/map-styles/index.css') }}" rel="stylesheet">
{% endblock %}

{% block beforeContent %}
  {{ backLink({href: backLinkPath}) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column">

      <h1 class="govuk-heading-l">{{ pageHeading }}</h1>

      {% if boundaryError %}
        <p class="govuk-body">{{ boundaryError }} <a href="{{ boundaryTypePath }}" class="govuk-link">Upload a new file or draw on a map</a></p>
      {% endif %}

      {% if showMap %}
      <div id="boundary-map" class="govuk-!-margin-bottom-6"
           data-existing-boundary-geojson='{{ boundaryGeojson | safe }}'
           data-existing-boundary-metadata='{{ existingBoundaryMetadata | safe }}'>
      </div>
      {% endif %}
      {% if intersectsEdp and not boundaryError %}
        <h2 class="govuk-heading-m">Red line boundary</h2>
        <p class="govuk-body">
          Your red line boundary is within {{ intersectingEdps | length }} Environmental Delivery
          Plan{{ "s" if intersectingEdps | length != 1 }} (EDP):
        </p>
        <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-2">
          {% for edp in intersectingEdps %}
            <li>
              {{ edp.label }}{% if edp.overlap_area_ha %} overlap: {{ edp.overlap_area_ha }}{% endif %} {% if edp.overlap_percentage %}({{ edp.overlap_percentage }}% of boundary){% endif %}
            </li>
          {% endfor %}
        </ul>
        <hr class="govuk-!-margin-top-8 govuk-!-margin-bottom-8" />
        <form method="post" novalidate>
          {% include "partials/csrf-token.njk" %}
          <div class="govuk-button-group">
            {{ govukButton({
              text: "Save and continue",
              preventDoubleClick: true
            }) }}
            <a href="{{ boundaryTypePath }}" class="govuk-link">Upload a new file or draw on a map</a>
          </div>
        </form>
      {% endif %}

    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
{% endblock %}

{% extends "layouts/page.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block beforeContent %}
  {{ backLink({href: backLinkPath}) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <h1 class="govuk-heading-l">{{ pageHeading }}</h1>

        {# boundaryFilename (below) is user-controlled. Safe here because
           govukSummaryList escapes value.text (but NOT value.html), and the
           backend validates it against a strict allowlist. Do NOT switch to html:. #}
        {{ govukSummaryList({
          classes: "govuk-!-margin-bottom-9",
          rows: [
            {
              key: { text: "Planning application type" },
              value: { text: planningTypeLabel },
              actions: { items: [{ href: "/quote/planning-type", text: "Change", visuallyHiddenText: "planning application type" }] }
            } if formSubmitData.planningType,
            {
              key: { text: "Red line boundary" },
              value: {
                text:
                  formSubmitData.boundaryFilename
                    if formSubmitData.boundaryEntryType === 'upload' and formSubmitData.boundaryFilename
                    else ('Uploaded' if formSubmitData.boundaryEntryType === 'upload' else 'Drawn')
              },
              actions: { items: [{ href: "/quote/upload-boundary" if formSubmitData.boundaryEntryType === 'upload' else "/quote/draw-boundary", text: "Change", visuallyHiddenText: "red line boundary" }] }
            } if formSubmitData.boundaryEntryType,
            {
              key: { text: "Number of units" },
              value: { text: formSubmitData.residentialBuildingCount },
              actions: { items: [{ href: "/quote/units", text: "Change", visuallyHiddenText: "number of units" }] }
            } if formSubmitData.residentialBuildingCount,
            {
              key: { text: "Email address" },
              value: { text: formSubmitData.email },
              actions: { items: [{ href: "/quote/email", text: "Change", visuallyHiddenText: "email address" }] }
            } if formSubmitData.email
          ]
        }) }}

        <form method="post" novalidate>
          {% include "partials/csrf-token.njk" %}
          <div class="govuk-button-group">
            {{ govukButton({
              text: "Submit",
              preventDoubleClick: true
            }) }}
            {{ govukButton({
              text: "Delete",
              classes: "govuk-button--warning",
              href: '/quote/delete-quote'
            }) }}
          </div>

        </form>
    </div>
</div>
{% endblock %}

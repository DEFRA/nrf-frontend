{
  "name": "nrf-frontend",
  "version": "0.0.0",
  "description": "CDP Frontend Template",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "build:frontend": "cross-env NODE_ENV=production webpack",
    "check:node-version": "test $(node --version | cut -d. -f1 | tr -d v) -ge 24 || (echo 'ERROR: This project requires Node.js >= 24.' && exit 1)",
    "dev": "npm run check:node-version && cross-env-shell GIT_HASH=$(git rev-parse HEAD) USE_SWAGGER=true run-p frontend:watch server:watch",
    "dev:debug": "npm run check:node-version && cross-env-shell GIT_HASH=$(git rev-parse HEAD) USE_SWAGGER=true run-p frontend:watch server:debug",
    "docker:dev": "npm run check:node-version && cross-env USE_SWAGGER=true run-p frontend:watch server:watch",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "frontend:watch": "cross-env NODE_ENV=development webpack --watch",
    "git:pre-commit-hook": "npm run security-audit && npm run format:check && npm run lint && npm test",
    "postinstall": "npm run setup:husky",
    "security-audit": "npm audit --audit-level=moderate",
    "lint": "run-s lint:js lint:scss",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "test": "cross-env TZ=UTC vitest run --coverage",
    "test:watch": "cross-env TZ=UTC vitest",
    "server:watch": "nodemon --inspect=0.0.0.0:9230 --ext js,json --legacy-watch ./src",
    "server:debug": "nodemon --inspect-brk=0.0.0.0:9230 --ext js,json --legacy-watch ./src",
    "prestart": "npm run build:frontend",
    "start": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "overrides": {
    "swagger-jsdoc": {
      "yaml": "2.0.0-1"
    },
    "joi": "$joi"
  },
  "dependencies": {
    "@defra/cdp-auditing": "^0.6.1",
    "@defra/hapi-secure-context": "^0.4.0",
    "@defra/hapi-tracing": "^1.30.0",
    "@defra/interactive-map": "^0.0.33-alpha",
    "@defra/nrf-library": "github:DEFRA/nrf-library#v1.6.0",
    "@elastic/ecs-pino-format": "^1.5.0",
    "@hapi/bell": "^13.1.0",
    "@hapi/catbox-memory": "^6.0.2",
    "@hapi/catbox-redis": "^7.0.2",
    "@hapi/crumb": "^9.0.1",
    "@hapi/hapi": "^21.4.9",
    "@hapi/inert": "^7.1.2",
    "@hapi/jwt": "^3.2.4",
    "@hapi/scooter": "^8.0.0",
    "@hapi/vision": "^7.0.3",
    "@hapi/wreck": "^18.1.2",
    "@hapi/yar": "^11.0.3",
    "aws-embedded-metrics": "^4.2.1",
    "blankie": "^5.0.0",
    "convict": "^6.2.5",
    "convict-format-with-validator": "^6.2.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "govuk-frontend": "^6.3.0",
    "hapi-pino": "^13.0.0",
    "hapi-pulse": "^4.0.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.3",
    "lodash": "^4.18.1",
    "maplibre-gl": "^5.24.0",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^11.2.0",
    "semver": "^7.8.5",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-dist": "^5.32.8",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^8.0.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "babel-loader": "^10.1.1",
    "cheerio": "^1.2.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.2",
    "cssnano-preset-default": "^8.0.2",
    "eslint": "^9.39.5",
    "eslint-plugin-no-secrets": "^2.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "neostandard": "^0.13.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "postcss-load-config": "^6.0.1",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^17.0.0",
    "source-map-loader": "^5.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-gds": "^3.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0",
    "webpack": "^5.108.4",
    "webpack-assets-manifest": "^6.5.2",
    "webpack-cli": "^7.2.1",
    "yaml": "^2.9.0"
  }
}
